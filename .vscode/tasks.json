{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm build",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "problemMatcher": []
    },
    {
      "label": "cargo build (tauri debug)",
      "type": "shell",
      "command": "cargo",
      "args": ["build", "--manifest-path", "src-tauri/Cargo.toml"],
      "problemMatcher": []
    },
    {
      "label": "cargo build (tauri debug macOS arm64)",
      "type": "shell",
      "command": "cargo",
      "args": [
        "build",
        "--manifest-path",
        "src-tauri/Cargo.toml",
        "--target",
        "aarch64-apple-darwin"
      ],
      "problemMatcher": []
    },
    {
      "label": "kill running KKTerm processes",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "try { Get-Process -Name kkterm,kkterm-cli -ErrorAction SilentlyContinue | Stop-Process -Force -ErrorAction SilentlyContinue } catch { }; exit 0"
      ],
      "problemMatcher": []
    },
    {
      "label": "kill running KKTerm processes (macOS)",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "pkill -x kkterm >/dev/null 2>&1 || true; pkill -x KKTerm >/dev/null 2>&1 || true"
      ],
      "problemMatcher": []
    },
    {
      "label": "start Vite dev server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE.*",
          "endsPattern": ".*Local:\\s+http://localhost:1420/.*"
        }
      }
    },
    {
      "label": "build KKTerm exe",
      "dependsOrder": "sequence",
      "dependsOn": ["npm build", "cargo build (tauri debug)"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "debug KKTerm exe",
      "dependsOrder": "sequence",
      "dependsOn": [
        "kill running KKTerm processes",
        "cargo build (tauri debug)",
        "start Vite dev server"
      ],
      "problemMatcher": []
    },
    {
      "label": "debug KKTerm macOS arm64",
      "dependsOrder": "sequence",
      "dependsOn": [
        "kill running KKTerm processes (macOS)",
        "cargo build (tauri debug macOS arm64)",
        "start Vite dev server"
      ],
      "problemMatcher": []
    }
  ]
}
